{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://lifeos.enterprise/schemas/Tool.schema.json",
  "title": "Tool",
  "description": "Defines an MCP connector or integration tool in the LifeOS tool registry.",
  "type": "object",
  "required": [
    "id",
    "name",
    "type",
    "status",
    "created",
    "updated"
  ],
  "properties": {
    "id": {
      "type": "string",
      "pattern": "^TOOL-[A-Z0-9]{4,}$"
    },
    "name": {
      "type": "string"
    },
    "slug": {
      "type": "string",
      "pattern": "^[a-z0-9-]+$"
    },
    "type": {
      "type": "string",
      "enum": [
        "MCP",
        "API",
        "Webhook",
        "Native",
        "CLI",
        "SDK"
      ]
    },
    "category": {
      "type": "string",
      "enum": [
        "AI Model",
        "Code",
        "Communication",
        "Data",
        "Design",
        "DevOps",
        "Finance",
        "Productivity",
        "Storage",
        "Other"
      ]
    },
    "status": {
      "type": "string",
      "enum": [
        "Active",
        "Inactive",
        "Degraded",
        "Deprecated",
        "Planned"
      ]
    },
    "version": {
      "type": "string"
    },
    "provider": {
      "type": "string"
    },
    "auth_type": {
      "type": "string",
      "enum": [
        "API Key",
        "OAuth2",
        "******",
        "Basic Auth",
        "None",
        "Other"
      ]
    },
    "capabilities": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "permissions": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "rate_limits": {
      "$ref": "#/$defs/RateLimits"
    },
    "health_endpoint": {
      "type": "string",
      "format": "uri"
    },
    "documentation_url": {
      "type": "string",
      "format": "uri"
    },
    "created": {
      "type": "string",
      "format": "date"
    },
    "updated": {
      "type": "string",
      "format": "date"
    }
  },
  "$defs": {
    "RateLimits": {
      "type": "object",
      "properties": {
        "requests_per_minute": {
          "type": "integer"
        },
        "requests_per_day": {
          "type": "integer"
        },
        "tokens_per_minute": {
          "type": "integer"
        }
      }
    }
  },
  "additionalProperties": false
}